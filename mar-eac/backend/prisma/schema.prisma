  updatedAt         DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicle      TransportVehicle?  @relation(fields: [assignedVehicleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
