generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Organization {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  email       String    @unique
  phone       String?
  address     String?
  city        String?
  region      String?
  logo        String?
  description  String?
  foundingDate DateTime?
  activities   String?
  adminHistory String?
  // ── Arabic profile ──────────────────────────────
  nameAr         String?
  cityAr         String?
  regionAr       String?
  addressAr      String?
  descriptionAr  String?
  activitiesAr   String?
  adminHistoryAr String?
  // ── Social media ────────────────────────────────
  whatsapp  String?
  facebook  String?
  instagram String?
  tiktok    String?
  youtube   String?
  // ── WhatsApp instance (Evolution API) ───────────
  evolutionInstance String?
  // ── Bank (shared) ───────────────────────────────
  bankName     String?
  bankAccount  String?
  bankRib      String?
  trialEndsAt  DateTime?
  modules      String[]  @default([])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  subscription       Subscription?
  users              User[]
  members            Member[]
  meetings           Meeting[]
  transactions       Transaction[]
  documents          Document[]
  projects           Project[]
  requests           Request[]
  waterInstallations WaterInstallation[]
  waterRepairs       WaterRepair[]
  reminders          Reminder[]
  waterTariff        WaterTariff?
  products           AssocProduct[]
  productions        AssocProduction[]
  productSales       AssocSale[]
  assocClients       AssocClient[]
  assocEvents        AssocEvent[]
  payments           Payment[]
  // Transport module
  transportDrivers       TransportDriver[]
  transportVehicles      TransportVehicle[]
  transportStudents      TransportStudent[]
  transportRoutes        TransportRoute[]
  transportSubscriptions TransportSubscription[]
  transportPayments      TransportPayment[]
  transportAttendances   TransportAttendance[]
  transportExpenses      TransportExpense[]
  // Pro features
  activityLogs       ActivityLog[]
  notifications      Notification[]
  recurringPayments  RecurringPayment[]
  backupRecords      BackupRecord[]
}

model Subscription {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @unique @db.ObjectId
  plan           String   @default("BASIC")
  status         String   @default("TRIAL")
  pendingPlan    String?
  startsAt       DateTime @default(now())
  expiresAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model User {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String?  @db.ObjectId
  email          String   @unique
  password       String
  name           String
  role           String   @default("ADMIN")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Member {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  name           String
  phone          String?
  email          String?
  role           String   @default("MEMBER")
  joinDate       DateTime @default(now())
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  meetingAttendances MeetingAttendance[]
  votes              Vote[]
}

model Meeting {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  title          String
  date           DateTime
  location       String?
  agenda         String?
  status         String   @default("SCHEDULED")
  pvUrl          String?
  pvContent      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  attendances  MeetingAttendance[]
  decisions    Decision[]
  sessions     VotingSession[]
  documents    Document[]
}

model MeetingAttendance {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  meetingId String  @db.ObjectId
  memberId  String  @db.ObjectId
  present   Boolean @default(false)
  role      String?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  member  Member  @relation(fields: [memberId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([meetingId, memberId])
}

model Decision {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  meetingId   String    @db.ObjectId
  description String
  assignedTo  String?
  dueDate     DateTime?
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model VotingSession {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  meetingId   String    @db.ObjectId
  title       String
  description String?
  isOpen      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  closedAt    DateTime?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  votes   Vote[]
}

model Vote {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  votingSessionId String   @db.ObjectId
  memberId        String   @db.ObjectId
  choice          String
  createdAt       DateTime @default(now())

  votingSession VotingSession @relation(fields: [votingSessionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  member        Member        @relation(fields: [memberId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([votingSessionId, memberId])
}

model Transaction {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  type           String
  amount         Float
  category       String
  description    String?
  date           DateTime @default(now())
  reference      String?
  docRef         String?
  receiptUrl     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Document {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  title          String
  type           String   @default("OTHER")
  url            String
  filename       String?
  size           Int?
  meetingId      String?  @db.ObjectId
  projectId      String?  @db.ObjectId
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  meeting      Meeting?     @relation(fields: [meetingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Project {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String    @db.ObjectId
  title          String
  type           String    @default("OTHER")
  description    String?
  location       String?
  status         String    @default("PLANNED")
  startDate      DateTime?
  endDate        DateTime?
  code           String?
  generalGoal    String?
  specificGoals  String?
  manager        String?
  budget         Float?
  beneficiaries  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  funding      Funding?
  requests     Request[]
  documents    Document[]
  milestones   ProjectMilestone[]
}

model ProjectMilestone {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  projectId   String    @db.ObjectId
  title       String
  description String?
  plannedDate DateTime?
  actualDate  DateTime?
  status      String    @default("PENDING")
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Funding {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId    String   @unique @db.ObjectId
  totalBudget  Float    @default(0)
  fundedAmount Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project Project        @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  entries FundingEntry[]
}

model FundingEntry {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  fundingId String   @db.ObjectId
  source    String
  amount    Float
  donor     String?
  date      DateTime @default(now())
  notes     String?

  funding Funding @relation(fields: [fundingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Request {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String    @db.ObjectId
  projectId      String?   @db.ObjectId
  title          String
  type           String    @default("COMMUNE")
  description    String?
  status         String    @default("PENDING")
  recipient      String?
  amount         Float?
  submittedAt    DateTime  @default(now())
  respondedAt    DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model WaterInstallation {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  readerId       String?  @db.ObjectId
  householdName  String
  phone          String?
  address        String?
  meterNumber    String
  installDate    DateTime @default(now())
  pricePerUnit   Float    @default(5.0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  readings     MeterReading[]
  invoices     WaterInvoice[]
  repairs      WaterRepair[]

  @@unique([organizationId, meterNumber])
}

model MeterReading {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  installationId  String   @db.ObjectId
  readingDate     DateTime
  previousReading Float    @default(0)
  currentReading  Float
  consumption     Float
  month           Int
  year            Int
  notes           String?
  createdAt       DateTime @default(now())

  installation WaterInstallation @relation(fields: [installationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  invoice      WaterInvoice?

  @@unique([installationId, month, year])
}

model WaterInvoice {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  readingId      String    @unique @db.ObjectId
  installationId String    @db.ObjectId
  amount         Float
  isPaid         Boolean   @default(false)
  paidAt         DateTime?
  dueDate        DateTime
  createdAt      DateTime  @default(now())

  reading      MeterReading      @relation(fields: [readingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  installation WaterInstallation @relation(fields: [installationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payment      WaterPayment?
}

model WaterPayment {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  invoiceId  String   @unique @db.ObjectId
  amount     Float
  method     String   @default("CASH")
  reference  String?
  receiptUrl String?
  notes      String?
  paidAt     DateTime @default(now())
  createdAt  DateTime @default(now())

  invoice WaterInvoice @relation(fields: [invoiceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model WaterRepair {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  organizationId   String    @db.ObjectId
  installationId   String?   @db.ObjectId
  title            String
  type             String    @default("REPARATION")
  description      String?
  location         String?
  status           String    @default("PENDING")
  cost             Float?
  reference        String?
  technicianName   String?
  technicianAmount Float?
  partsNeeded      String?
  workDetails      String?
  deadline         DateTime?
  reportedDate     DateTime  @default(now())
  resolvedDate     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  installation WaterInstallation? @relation(fields: [installationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model WaterTariff {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @unique @db.ObjectId
  fixedFee       Float    @default(0)
  tranches       Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ── Productive Association Module ─────────────────────────────────────────────

model AssocProduct {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  name           String
  nameAr         String?
  category       String?
  unit           String   @default("unité")
  price          Float    @default(0)
  lowStockAlert  Float    @default(10)
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productions  AssocProduction[]
  saleItems    AssocSaleItem[]
}

model AssocClient {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  name           String
  phone          String?
  email          String?
  address        String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales        AssocSale[]
}

model AssocSale {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId  String   @db.ObjectId
  clientId        String?  @db.ObjectId
  totalAmount     Float
  date            DateTime @default(now())
  notes           String?
  transactionId   String?  @db.ObjectId
  createdAt       DateTime @default(now())

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  client       AssocClient?   @relation(fields: [clientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items        AssocSaleItem[]
}

model AssocSaleItem {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  saleId     String @db.ObjectId
  productId  String @db.ObjectId
  quantity   Float
  unitPrice  Float
  subtotal   Float

  sale    AssocSale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product AssocProduct @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model AssocProduction {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId   String   @db.ObjectId
  productId        String   @db.ObjectId
  quantityProduced Float
  productionCost   Float    @default(0)
  date             DateTime @default(now())
  notes            String?
  transactionId    String?  @db.ObjectId
  createdAt        DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product      AssocProduct @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model AssocEvent {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  name           String
  type           String   @default("EVENT")
  date           DateTime
  location       String?
  description    String?
  revenue        Float    @default(0)
  cost           Float    @default(0)
  incomeTransId  String?  @db.ObjectId
  expenseTransId String?  @db.ObjectId
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Reminder {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  type           String
  title          String
  message        String?
  isRead         Boolean  @default(false)
  scheduledFor   DateTime
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Payment {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  amount         Float
  method         String   @default("CASH")
  reference      String?
  receiptUrl     String?
  note           String?
  paidAt         DateTime @default(now())
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ── SaaS Management Models ────────────────────────────────────────────────────

model Pack {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  nameAr      String?
  description String?
  descriptionAr String?
  price       Float
  currency    String   @default("MAD")
  billingCycle String  @default("MONTHLY") // MONTHLY, YEARLY
  assocType   String   // REGULAR, PROJECTS, WATER, PRODUCTIVE, PRODUCTIVE_WATER
  size        String   @default("MEDIUM") // SMALL, MEDIUM, LARGE
  features    String[] @default([])
  featuresAr  String[] @default([])
  limits      Json     @default("{}")
  isActive    Boolean  @default(true)
  trialDays   Int      @default(15)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PromoCode {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  code          String    @unique
  description   String?
  discountType  String    @default("PERCENTAGE") // PERCENTAGE, FIXED
  discountValue Float
  maxUses       Int?
  usedCount     Int       @default(0)
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  applicableTo  String[]  @default([]) // assoc types it applies to, empty = all
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model EmailCampaign {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  subject     String
  body        String
  targetGroup String   @default("ALL") // ALL, TRIAL, ACTIVE, EXPIRED, INACTIVE
  status      String   @default("DRAFT") // DRAFT, SENT, SCHEDULED
  sentAt      DateTime?
  scheduledAt DateTime?
  recipientCount Int   @default(0)
  openCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WhatsAppMessage {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String?  @db.ObjectId
  phone          String
  message        String
  type           String   @default("MANUAL") // MANUAL, AUTOMATED
  trigger        String?  // TRIAL_EXPIRY, PAYMENT_REMINDER, PROMOTION, INACTIVE
  status         String   @default("PENDING") // PENDING, SENT, FAILED
  sentAt         DateTime?
  createdAt      DateTime @default(now())
}

model AutomationRule {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  nameAr      String?
  trigger     String   // TRIAL_EXPIRED, PAYMENT_OVERDUE, INACTIVE_30D, INACTIVE_60D, SUBSCRIPTION_EXPIRING
  conditions  Json     @default("{}")
  actions     Json     @default("[]") // [{type: 'EMAIL'|'WHATSAPP', template: '...'}]
  isActive    Boolean  @default(true)
  lastRun     DateTime?
  runCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PlatformSettings {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  key             String   @unique
  value           String
  category        String   @default("GENERAL") // GENERAL, BILLING, INTEGRATIONS, NOTIFICATIONS
  updatedAt       DateTime @updatedAt
}

model MarketingCampaign {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  campaignType      String    @default("no_template")
  sendType          String    @default("bulk")           // manual | bulk
  segmentation      String[]
  messageContent    String
  scheduleType      String    @default("now")            // now | scheduled
  scheduleDate      DateTime?
  tracking          Json      @default("{\"sent\":false,\"opened\":false,\"clicked\":false}")
  automationEnabled Boolean   @default(false)
  automationTrigger String?
  status            String    @default("DRAFT")          // DRAFT | SENT | SCHEDULED | FAILED
  sentAt            DateTime?
  recipientCount    Int       @default(0)
  n8nJobId          String?
  channel           String    @default("whatsapp")       // whatsapp | email | both
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("marketing_campaigns")
}

// ── School Transport Module ───────────────────────────────────────────────────

model TransportDriver {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  fullName       String
  phone          String?
  cinNumber      String?  // National ID
  licenseNumber  String?
  licenseExpiry  DateTime?
  address        String?
  status         String   @default("ACTIVE") // ACTIVE | INACTIVE | ON_LEAVE
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicles     TransportVehicle[]

  @@index([organizationId])
}

model TransportVehicle {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  name           String
  plateNumber    String
  capacity       Int      @default(20)
  driverId       String?  @db.ObjectId
  driverName     String?  // kept for backward-compat / quick display
  driverPhone    String?
  status         String   @default("ACTIVE") // ACTIVE | MAINTENANCE
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  driver       TransportDriver?  @relation(fields: [driverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students     TransportStudent[]
  routes       TransportRoute[]
}

model TransportStudent {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId    String   @db.ObjectId
  fullName          String
  school            String?
  address           String?
  phone             String?
  parentName        String?
  parentPhone       String?
  assignedVehicleId String?  @db.ObjectId
  routeId           String?  @db.ObjectId
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicle        TransportVehicle?      @relation(fields: [assignedVehicleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  route          TransportRoute?        @relation(fields: [routeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subscriptions  TransportSubscription[]
  payments       TransportPayment[]
  attendances    TransportAttendance[]
}

model TransportRoute {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId    String   @db.ObjectId
  routeName         String
  stops             String[] @default([])
  assignedVehicleId String?  @db.ObjectId
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicle      TransportVehicle?  @relation(fields: [assignedVehicleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students     TransportStudent[]
}

model TransportSubscription {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  studentId      String   @db.ObjectId
  monthlyFee     Float
  month          Int
  year           Int
  status         String   @default("UNPAID") // PAID | UNPAID
  startDate      DateTime @default(now())
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  student      TransportStudent @relation(fields: [studentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([studentId, month, year])
}

model TransportPayment {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  studentId      String   @db.ObjectId
  amount         Float
  date           DateTime @default(now())
  method         String   @default("CASH") // CASH | TRANSFER | CHECK
  status         String   @default("PAID") // PAID | PENDING
  transactionId  String?  @db.ObjectId
  notes          String?
  createdAt      DateTime @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  student      TransportStudent @relation(fields: [studentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model TransportAttendance {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  studentId      String   @db.ObjectId
  date           DateTime
  status         String   @default("PRESENT") // PRESENT | ABSENT
  notes          String?
  createdAt      DateTime @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  student      TransportStudent @relation(fields: [studentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([studentId, date])
}

model TransportExpense {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  vehicleId      String?  @db.ObjectId
  category       String   // FUEL | MAINTENANCE | INSURANCE | OTHER
  amount         Float
  date           DateTime @default(now())
  description    String?
  transactionId  String?  @db.ObjectId
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

// ── Activity Log ──────────────────────────────────────────────────────────────
model ActivityLog {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  userId         String?  @db.ObjectId
  userName       String?
  userRole       String?
  action         String
  entity         String
  entityId       String?
  description    String
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([organizationId, createdAt])
}

// ── Notifications ─────────────────────────────────────────────────────────────
model Notification {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  userId         String?  @db.ObjectId
  type           String   @default("INFO")
  title          String
  titleAr        String?
  body           String?
  bodyAr         String?
  link           String?
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([organizationId, isRead, createdAt])
}

// ── Recurring Payments ────────────────────────────────────────────────────────
model RecurringPayment {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  description    String
  amount         Float
  category       String
  type           String   @default("INCOME")
  frequency      String   @default("MONTHLY")
  startDate      DateTime
  nextDueDate    DateTime
  lastRunDate    DateTime?
  isActive       Boolean  @default(true)
  autoCreate     Boolean  @default(true)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

// ── Backup Records ────────────────────────────────────────────────────────────
model BackupRecord {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  createdByName  String?
  sizeKb         Int      @default(0)
  status         String   @default("DONE") // DONE | FAILED
  note           String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  @@index([organizationId, createdAt])
}
