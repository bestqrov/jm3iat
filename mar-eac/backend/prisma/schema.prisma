generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Organization {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  email       String    @unique
  phone       String?
  address     String?
  city        String?
  region      String?
  logo        String?
  description  String?
  foundingDate       DateTime?
  bureauCreationDate DateTime?
  mandateDuration    Int?      // term length in years: 1, 2, 3, 4, or custom
  activities         String?
  adminHistory       String?
  // ── Arabic profile ──────────────────────────────
  nameAr         String?
  cityAr         String?
  regionAr       String?
  addressAr      String?
  descriptionAr  String?
  activitiesAr   String?
  adminHistoryAr String?
  // ── Social media ────────────────────────────────
  whatsapp  String?
  facebook  String?
  instagram String?
  tiktok    String?
  youtube   String?
  // ── WhatsApp instance (Evolution API) ───────────
  evolutionInstance String?
  // ── Bank (shared) ───────────────────────────────
  bankName     String?
  bankAccount  String?
  bankRib      String?
  membershipFee Float?
  assocType    String?   // REGULAR, PROJECTS, WATER, PRODUCTIVE, SPORTIF, PRO
  trialEndsAt  DateTime?
  modules      String[]  @default([])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  subscription       Subscription?
  users              User[]
  members            Member[]
  meetings           Meeting[]
  transactions       Transaction[]
  documents          Document[]
  projects           Project[]
  requests           Request[]
  waterInstallations WaterInstallation[]
  waterRepairs       WaterRepair[]
  reminders          Reminder[]
  waterTariff        WaterTariff?
  products           AssocProduct[]
  productions        AssocProduction[]
  productSales       AssocSale[]
  assocClients       AssocClient[]
  assocEvents        AssocEvent[]
  payments           Payment[]
  // Transport module
  transportDrivers       TransportDriver[]
  transportVehicles      TransportVehicle[]
  transportStudents      TransportStudent[]
  transportRoutes        TransportRoute[]
  transportSubscriptions TransportSubscription[]
  transportPayments      TransportPayment[]
  transportAttendances   TransportAttendance[]
  transportExpenses      TransportExpense[]
  // Sports module
  sportPlayers     SportPlayer[]
  sportTeams       SportTeam[]
  sportTrainings   SportTraining[]
  sportMatches     SportMatch[]
  // Cooperatives module
  ice               String?
  registreCommerce  String?
  identifiantFiscal String?
  capitalSocial     Float?
  partsValeur       Float?
  coopType          String?
  // Conversion flow: NONE (default) | PENDING_CONVERSION | CONVERTED
  conversionStatus        String?   @default("NONE")
  conversionRequestedAt   DateTime?
  conversionApprovedAt    DateTime?
  coopStockProducts  CoopStockProduct[]
  coopStockMovements CoopStockMovement[]
  coopMemberShares   CoopMemberShare[]
  coopInvoices       CoopInvoice[]
  coopProductions    CoopProduction[]
  coopClients        CoopClient[]
  coopSales          CoopSale[]
  promoCodeUsages    PromoCodeUsage[]
  // Commerce module
  commerceProducts      CommerceProduct[]
  commerceStockMovements CommerceStockMovement[]
  commerceOrders        CommerceOrder[]
  commerceOrderProfits  CommerceOrderProfit[]
  commercePayouts       CommercePayout[]
  // Pro features
  activityLogs       ActivityLog[]
  notifications      Notification[]
  recurringPayments  RecurringPayment[]
  backupRecords      BackupRecord[]
  assets             Asset[]
}

model Subscription {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @unique @db.ObjectId
  plan           String   @default("BASIC")
  status         String   @default("TRIAL")
  pendingPlan    String?
  startsAt       DateTime @default(now())
  expiresAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model User {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String?  @db.ObjectId
  email          String   @unique
  password       String
  name           String
  role           String   @default("ADMIN")
  isActive       Boolean  @default(true)
  whatsapp       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Member {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  name           String
  phone          String?
  email          String?
  role           String   @default("MEMBER")
  joinDate       DateTime @default(now())
  isActive       Boolean  @default(true)
  paymentReceiptUrl String?
  notifyChannel     String?
  lastRenewalYear   Int?
  lastRenewalDate   DateTime?
  renewalRemindedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  meetingAttendances MeetingAttendance[]
  votes              Vote[]
}

model Meeting {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  title          String
  date           DateTime
  location       String?
  agenda         String?
  status         String   @default("SCHEDULED")
  meetingType    String?  @default("GA")
  pvUrl          String?
  pvContent      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  attendances  MeetingAttendance[]
  decisions    Decision[]
  sessions     VotingSession[]
  documents    Document[]
}

model MeetingAttendance {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  meetingId String  @db.ObjectId
  memberId  String  @db.ObjectId
  present   Boolean @default(false)
  role      String?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  member  Member  @relation(fields: [memberId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([meetingId, memberId])
}

model Decision {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  meetingId   String    @db.ObjectId
  description String
  assignedTo  String?
  dueDate     DateTime?
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model VotingSession {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  meetingId   String    @db.ObjectId
  title       String
  description String?
  isOpen      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  closedAt    DateTime?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  votes   Vote[]
}

model Vote {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  votingSessionId String   @db.ObjectId
  memberId        String   @db.ObjectId
  choice          String
  createdAt       DateTime @default(now())

  votingSession VotingSession @relation(fields: [votingSessionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  member        Member        @relation(fields: [memberId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([votingSessionId, memberId])
}

model Transaction {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  type           String
  amount         Float
  category       String
  description    String?
  date           DateTime @default(now())
  reference      String?
  docRef         String?
  receiptUrl     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Document {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  title          String
  type           String   @default("OTHER")
  url            String
  filename       String?
  size           Int?
  documentDate   DateTime?
  meetingId      String?  @db.ObjectId
  projectId      String?  @db.ObjectId
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  meeting      Meeting?     @relation(fields: [meetingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Project {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String    @db.ObjectId
  title          String
  type           String    @default("OTHER")
  description    String?
  location       String?
  status         String    @default("PLANNED")
  startDate      DateTime?
  endDate        DateTime?
  code           String?
  generalGoal    String?
  specificGoals  String?
  manager        String?
  budget         Float?
  beneficiaries  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  technicalCard  Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  funding      Funding?
  requests     Request[]
  documents    Document[]
  milestones   ProjectMilestone[]
}

model ProjectMilestone {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  projectId   String    @db.ObjectId
  title       String
  description String?
  plannedDate DateTime?
  actualDate  DateTime?
  status      String    @default("PENDING")
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Funding {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId    String   @unique @db.ObjectId
  totalBudget  Float    @default(0)
  fundedAmount Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project Project        @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  entries FundingEntry[]
}

model FundingEntry {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  fundingId String   @db.ObjectId
  source    String
  amount    Float
  donor     String?
  date      DateTime @default(now())
  notes     String?

  funding Funding @relation(fields: [fundingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Request {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String    @db.ObjectId
  projectId      String?   @db.ObjectId
  title          String
  type           String    @default("COMMUNE")
  description    String?
  status         String    @default("PENDING")
  recipient      String?
  amount         Float?
  submittedAt    DateTime  @default(now())
  respondedAt    DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model WaterInstallation {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  readerId       String?  @db.ObjectId
  householdName  String
  phone          String?
  address        String?
  meterNumber    String
  installDate    DateTime @default(now())
  pricePerUnit   Float    @default(5.0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  readings     MeterReading[]
  invoices     WaterInvoice[]
  repairs      WaterRepair[]

  @@unique([organizationId, meterNumber])
}

model MeterReading {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  installationId  String   @db.ObjectId
  readingDate     DateTime
  previousReading Float    @default(0)
  currentReading  Float
  consumption     Float
  month           Int
  year            Int
  notes           String?
  meterPhotoUrl   String?
  createdAt       DateTime @default(now())

  installation WaterInstallation @relation(fields: [installationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  invoice      WaterInvoice?

  @@unique([installationId, month, year])
}

model WaterInvoice {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  readingId      String    @unique @db.ObjectId
  installationId String    @db.ObjectId
  amount         Float
  isPaid         Boolean   @default(false)
  paidAt         DateTime?
  dueDate        DateTime
  createdAt      DateTime  @default(now())

  reading      MeterReading      @relation(fields: [readingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  installation WaterInstallation @relation(fields: [installationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payment      WaterPayment?
}

model WaterPayment {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  invoiceId  String   @unique @db.ObjectId
  amount     Float
  method     String   @default("CASH")
  reference  String?
  receiptUrl String?
  notes      String?
  paidAt     DateTime @default(now())
  createdAt  DateTime @default(now())

  invoice WaterInvoice @relation(fields: [invoiceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model WaterRepair {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  organizationId   String    @db.ObjectId
  installationId   String?   @db.ObjectId
  title            String
  type             String    @default("REPARATION")
  description      String?
  location         String?
  status           String    @default("PENDING")
  cost             Float?
  reference        String?
  technicianName   String?
  technicianAmount Float?
  partsNeeded      String?
  workDetails      String?
  deadline         DateTime?
  reportedDate     DateTime  @default(now())
  resolvedDate     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  installation WaterInstallation? @relation(fields: [installationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model WaterTariff {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @unique @db.ObjectId
  fixedFee       Float    @default(0)
  tranches       Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ── Productive Association Module ─────────────────────────────────────────────

model AssocProduct {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  name           String
  nameAr         String?
  category       String?
  unit           String   @default("unité")
  price          Float    @default(0)
  lowStockAlert  Float    @default(10)
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productions  AssocProduction[]
  saleItems    AssocSaleItem[]
}

model AssocClient {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  name           String
  phone          String?
  email          String?
  address        String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales        AssocSale[]
}

model AssocSale {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId  String   @db.ObjectId
  clientId        String?  @db.ObjectId
  totalAmount     Float
  date            DateTime @default(now())
  notes           String?
  transactionId   String?  @db.ObjectId
  createdAt       DateTime @default(now())

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  client       AssocClient?   @relation(fields: [clientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items        AssocSaleItem[]
}

model AssocSaleItem {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  saleId     String @db.ObjectId
  productId  String @db.ObjectId
  quantity   Float
  unitPrice  Float
  subtotal   Float

  sale    AssocSale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product AssocProduct @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model AssocProduction {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId   String   @db.ObjectId
  productId        String   @db.ObjectId
  quantityProduced Float
  productionCost   Float    @default(0)
  date             DateTime @default(now())
  notes            String?
  transactionId    String?  @db.ObjectId
  createdAt        DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product      AssocProduct @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model AssocEvent {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  name           String
  type           String   @default("EVENT")
  date           DateTime
  location       String?
  description    String?
  revenue        Float    @default(0)
  cost           Float    @default(0)
  incomeTransId  String?  @db.ObjectId
  expenseTransId String?  @db.ObjectId
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Reminder {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  type           String
  title          String
  message        String?
  isRead         Boolean  @default(false)
  scheduledFor   DateTime
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Payment {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  amount         Float
  method         String   @default("CASH")
  reference      String?
  receiptUrl     String?
  note           String?
  paidAt         DateTime @default(now())
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ── Asset Management ─────────────────────────────────────────────────────────

model Asset {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  name           String
  type           String   @default("OTHER")   // REAL_ESTATE | VEHICLE | EQUIPMENT | FURNITURE | OTHER
  description    String?
  reference      String?
  location       String?
  acquisitionDate DateTime?
  acquisitionValue Float?
  currentValue   Float?
  status         String   @default("ACTIVE")  // ACTIVE | MAINTENANCE | DEPRECATED | SOLD
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

// ── SaaS Management Models ────────────────────────────────────────────────────

model Pack {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  nameAr      String?
  description String?
  descriptionAr String?
  price       Float
  currency    String   @default("MAD")
  billingCycle String  @default("MONTHLY") // MONTHLY, YEARLY
  assocType   String   // REGULAR, PROJECTS, WATER, PRODUCTIVE, PRODUCTIVE_WATER
  size        String   @default("MEDIUM") // SMALL, MEDIUM, LARGE
  features    String[] @default([])
  featuresAr  String[] @default([])
  limits      Json     @default("{}")
  isActive    Boolean  @default(true)
  trialDays   Int      @default(15)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PromoSeller {
  id                String           @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  email             String           @unique
  phone             String
  bankName          String?
  bankAccount       String?
  bankHolder        String?
  commissionPerUse  Float            @default(0)
  isActive          Boolean          @default(true)
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  promoCodes        PromoCode[]
  usages            PromoCodeUsage[]
}

model PromoCode {
  id                 String           @id @default(auto()) @map("_id") @db.ObjectId
  code               String           @unique
  description        String?
  discountType       String           @default("PERCENTAGE")
  discountValue      Float
  maxUses            Int?
  usedCount          Int              @default(0)
  expiresAt          DateTime?
  isActive           Boolean          @default(true)
  applicableTo       String[]         @default([])
  sellerId           String?          @db.ObjectId
  commissionOverride Float?
  seller             PromoSeller?     @relation(fields: [sellerId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  usages             PromoCodeUsage[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model PromoCodeUsage {
  id               String       @id @default(auto()) @map("_id") @db.ObjectId
  promoCodeId      String       @db.ObjectId
  sellerId         String?      @db.ObjectId
  organizationId   String       @db.ObjectId
  orgName          String
  discountAmount   Float        @default(0)
  commissionAmount Float        @default(0)
  isPaid           Boolean      @default(false)
  usedAt           DateTime     @default(now())
  promoCode        PromoCode    @relation(fields: [promoCodeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  seller           PromoSeller? @relation(fields: [sellerId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model EmailCampaign {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  subject     String
  body        String
  targetGroup String   @default("ALL") // ALL, TRIAL, ACTIVE, EXPIRED, INACTIVE
  status      String   @default("DRAFT") // DRAFT, SENT, SCHEDULED
  sentAt      DateTime?
  scheduledAt DateTime?
  recipientCount Int   @default(0)
  openCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WhatsAppMessage {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String?  @db.ObjectId
  phone          String
  message        String
  type           String   @default("MANUAL") // MANUAL, AUTOMATED
  trigger        String?  // TRIAL_EXPIRY, PAYMENT_REMINDER, PROMOTION, INACTIVE
  status         String   @default("PENDING") // PENDING, SENT, FAILED
  sentAt         DateTime?
  createdAt      DateTime @default(now())
}

model AutomationRule {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  nameAr      String?
  trigger     String   // TRIAL_EXPIRED, PAYMENT_OVERDUE, INACTIVE_30D, INACTIVE_60D, SUBSCRIPTION_EXPIRING
  conditions  Json     @default("{}")
  actions     Json     @default("[]") // [{type: 'EMAIL'|'WHATSAPP', template: '...'}]
  isActive    Boolean  @default(true)
  lastRun     DateTime?
  runCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PlatformSettings {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  key             String   @unique
  value           String
  category        String   @default("GENERAL") // GENERAL, BILLING, INTEGRATIONS, NOTIFICATIONS
  updatedAt       DateTime @updatedAt
}

model MarketingCampaign {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  campaignType      String    @default("no_template")
  sendType          String    @default("bulk")           // manual | bulk
  segmentation      String[]
  messageContent    String
  scheduleType      String    @default("now")            // now | scheduled
  scheduleDate      DateTime?
  tracking          Json      @default("{\"sent\":false,\"opened\":false,\"clicked\":false}")
  automationEnabled Boolean   @default(false)
  automationTrigger String?
  status            String    @default("DRAFT")          // DRAFT | SENT | SCHEDULED | FAILED
  sentAt            DateTime?
  recipientCount    Int       @default(0)
  n8nJobId          String?
  channel           String    @default("whatsapp")       // whatsapp | email | both
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("marketing_campaigns")
}

// ── School Transport Module ───────────────────────────────────────────────────

model TransportDriver {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
